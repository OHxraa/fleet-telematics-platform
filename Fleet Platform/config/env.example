# FLEET TELEMATICS PLATFORM - ENVIRONMENT CONFIGURATION
# 
# Copy this file to .env and fill in your actual values
# Do NOT commit .env to version control
#
# IMPORTANT: Keep sensitive values (API keys, secrets) secure
# Use different values for development, staging, and production

# ============================================
# APPLICATION
# ============================================
NODE_ENV=development
APP_NAME=Fleet Telematics Platform
APP_URL=http://localhost:3000
API_URL=http://localhost:5000

# ============================================
# SERVER
# ============================================
BACKEND_PORT=5000
FRONTEND_PORT=3000

# ============================================
# DATABASE - PostgreSQL
# ============================================
DB_HOST=postgres
DB_PORT=5432
DB_USER=fleet_user
DB_PASSWORD=fleet_password
DB_NAME=fleet_platform

# Connection pooling
DB_POOL_MIN=2
DB_POOL_MAX=10

# ============================================
# CACHE - Redis
# ============================================
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# ============================================
# AUTHENTICATION
# ============================================
# JWT Secret - CHANGE THIS IN PRODUCTION!
JWT_SECRET=your-super-secret-key-change-in-production-12345
JWT_EXPIRY=24h
JWT_REFRESH_SECRET=your-refresh-secret-change-in-production-12345
JWT_REFRESH_EXPIRY=7d

# 2FA
ENABLE_2FA=true
2FA_ISSUER=Fleet Platform

# ============================================
# TELEMATICS PROVIDERS
# ============================================

# Sennder / Verizon Connect
SENNDER_API_KEY=
SENNDER_API_SECRET=
SENNDER_API_URL=https://api.sennder.com/v1

# TomTom Telematics
TOMTOM_API_KEY=
TOMTOM_API_URL=https://api.tomtom.com/

# Geotab
GEOTAB_USERNAME=
GEOTAB_PASSWORD=
GEOTAB_API_URL=https://my.geotab.com/api/v1

# ============================================
# PARTS SUPPLIERS
# ============================================

# BPW
BPW_API_KEY=
BPW_API_SECRET=
BPW_API_URL=https://api.bpw-ecom.com/v1
BPW_COMMISSION_RATE=0.10

# Meritor
MERITOR_API_KEY=
MERITOR_API_URL=https://api.meritor-parts.com/v2

# Hendrickson
HENDRICKSON_API_KEY=
HENDRICKSON_API_URL=https://partner-api.hendrickson.com

# ============================================
# EMAIL / NOTIFICATIONS
# ============================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=noreply@fleetplatform.com

# Email notifications
ENABLE_EMAIL_ALERTS=true
ALERT_EMAIL_RECIPIENTS=admin@example.com

# ============================================
# AWS (if using AWS for hosting)
# ============================================
AWS_REGION=eu-west-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=fleet-platform-bucket
AWS_RDS_ENDPOINT=

# ============================================
# GCP (if using Google Cloud)
# ============================================
GCP_PROJECT_ID=
GCP_CREDENTIALS_PATH=./credentials.json

# ============================================
# ENCRYPTION
# ============================================
# AES-256 encryption key (must be 32 bytes for AES-256)
ENCRYPTION_KEY=your-32-byte-encryption-key-change-this
ENCRYPTION_IV=your-16-byte-iv-value

# ============================================
# LOGGING
# ============================================
LOG_LEVEL=debug
LOG_FORMAT=json
LOG_FILE=./logs/app.log
LOG_MAX_SIZE=10m
LOG_MAX_FILES=14

# ============================================
# SECURITY
# ============================================
# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# CORS
CORS_ORIGIN=http://localhost:3000
CORS_CREDENTIALS=true

# Password requirements
PASSWORD_MIN_LENGTH=8
PASSWORD_REQUIRE_UPPERCASE=true
PASSWORD_REQUIRE_NUMBERS=true
PASSWORD_REQUIRE_SPECIAL=true

# ============================================
# FEATURES (TOGGLES)
# ============================================
FEATURE_TELEMATICS=true
FEATURE_WAREHOUSE=false
FEATURE_PREDICTIVE_ML=false
FEATURE_MULTI_TENANCY=false
FEATURE_WHITE_LABEL=false

# ============================================
# MAPS / LOCATION
# ============================================
MAPBOX_TOKEN=
MAPBOX_STYLE=mapbox://styles/mapbox/streets-v12

# ============================================
# DATA RETENTION
# ============================================
# How long to keep telematics data (days)
TELEMATICS_RETENTION_DAYS=90

# How long to keep logs (days)
LOG_RETENTION_DAYS=30

# ============================================
# BACKUP
# ============================================
BACKUP_ENABLED=true
BACKUP_FREQUENCY=daily
BACKUP_RETENTION_DAYS=30

# ============================================
# DEVELOPMENT ONLY
# ============================================
# Enable debug mode
DEBUG=false

# Seed database with sample data on startup
SEED_DATABASE=false

# Skip email sending (just log instead)
DRY_RUN_EMAIL=false

# Mock external APIs (for testing without real API keys)
MOCK_EXTERNAL_APIS=false

# ============================================
# ANALYTICS / MONITORING
# ============================================
SENTRY_DSN=
DATADOG_API_KEY=
ENABLE_APM=false

# ============================================
# STRIPE / PAYMENTS (Future)
# ============================================
STRIPE_PUBLIC_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ============================================
# SLACK INTEGRATION (Optional)
# ============================================
SLACK_WEBHOOK_URL=
SLACK_CHANNEL=#fleet-alerts
