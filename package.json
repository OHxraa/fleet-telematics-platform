{
  "name": "fleet-telematics-backend",
  "version": "1.0.0",
  "description": "Fleet Telematics SaaS Platform Backend",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "dev": "nodemon src/index.js",
    "migrate": "node scripts/migrate.js",
    "seed": "node scripts/seed.js",
    "test": "jest --detectOpenHandles",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint src --fix",
    "format": "prettier --write \"src/**/*.js\""
  },
  "keywords": [
    "fleet",
    "telematics",
    "geotab",
    "idem",
    "gps",
    "tracking"
  ],
  "author": "Fleet Telematics Team",
  "license": "MIT",
  "dependencies": {
    "express": "^4.18.2",
    "express-async-errors": "^3.1.1",
    "pg": "^8.8.0",
    "redis": "^4.6.5",
    "socket.io": "^4.5.4",
    "jsonwebtoken": "^9.0.0",
    "bcryptjs": "^2.4.3",
    "winston": "^3.8.2",
    "joi": "^17.9.1",
    "helmet": "^7.0.0",
    "cors": "^2.8.5",
    "uuid": "^9.0.0",
    "dotenv": "^16.0.3",
    "axios": "^1.4.0",
    "morgan": "^1.10.0",
    "compression": "^1.7.4",
    "express-rate-limit": "^6.7.0",
    "node-cache": "^5.1.2"
  },
  "devDependencies": {
    "nodemon": "^2.0.20",
    "jest": "^29.5.0",
    "supertest": "^6.3.3",
    "eslint": "^8.40.0",
    "prettier": "^2.8.8"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  }
}
