        code: 'FETCH_FAILED',
        message: error.message,
      },
    });
  }
}));

/**
 * GET /api/v1/vehicles/:id/stats
 * Get vehicle statistics
 */
router.get('/:id/stats', asyncHandler(async (req, res) => {
  try {
    const days = req.query.days || 7;
    const stats = await VehicleService.getVehicleStats(req.params.id, days);

    res.status(200).json({
      success: true,
      data: stats,
    });

  } catch (error) {
    logger.error('Error fetching stats:', error.message);

    res.status(500).json({
      success: false,
      error: {
        code: 'FETCH_FAILED',
        message: error.message,
      },
    });
  }
