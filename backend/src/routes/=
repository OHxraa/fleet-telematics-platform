/**
 * POST /api/v1/vehicles/sync-geotab
 * Sync vehicles from Geotab
 */
router.post('/sync-geotab', authorize('admin', 'manager'), asyncHandler(async (req, res) => {
  try {
    const customerId = req.query.customerId || 'demo-customer';

    const result = await VehicleService.syncAllVehiclesFromGeotab(customerId);

    res.status(200).json({
      success: true,
      data: result,
      message: 'Sync completed',
    });

  } catch (error) {
    logger.error('Sync error:', error.message);

    res.status(500).json({
      success: false,
      error: {
        code: 'SYNC_FAILED',
        message: error.message,
      },
    });
  }
}));

module.exports = router;
