# =====================================================
# Fleet Telematics Platform - Environment Configuration
# =====================================================

# ============================================
# SERVER CONFIGURATION
# ============================================
NODE_ENV=development
PORT=5000
LOG_LEVEL=info
APP_NAME=Fleet Telematics Platform

# ============================================
# DATABASE CONFIGURATION
# ============================================
DB_HOST=your-rds-endpoint.eu-west-1.rds.amazonaws.com
DB_PORT=5432
DB_NAME=database-1
DB_USER=postgres
DB_PASSWORD=your-secure-password
DB_POOL_MIN=2
DB_POOL_MAX=10

# ============================================
# REDIS CONFIGURATION
# ============================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ============================================
# GEOTAB CONFIGURATION
# ============================================
GEOTAB_API_ENDPOINT=https://my.geotab.com/api/v1
GEOTAB_USERNAME=your-geotab-username
GEOTAB_PASSWORD=your-geotab-password
GEOTAB_DATABASE=your-geotab-database
GEOTAB_POLLING_INTERVAL=30000

# ============================================
# IDEM CONFIGURATION
# ============================================
IDEM_API_ENDPOINT=
IDEM_AUTHENTICATION_TYPE=API_KEY
IDEM_API_KEY=
IDEM_ACCOUNT_ID=
IDEM_POLLING_INTERVAL=30000

# ============================================
# JWT CONFIGURATION
# ============================================
JWT_SECRET=your-jwt-secret-key-min-32-chars
JWT_EXPIRE=24h
JWT_REFRESH_SECRET=your-jwt-refresh-secret-key-min-32-chars
JWT_REFRESH_EXPIRE=7d

# ============================================
# CORS CONFIGURATION
# ============================================
CORS_ORIGIN=http://localhost:3000,http://localhost:5000
CORS_CREDENTIALS=true

# ============================================
# RATE LIMITING
# ============================================
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ============================================
# SESSION CONFIGURATION
# ============================================
SESSION_SECRET=your-session-secret-key

# ============================================
# EMAIL CONFIGURATION (Optional)
# ============================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=noreply@fleetplatform.com

# ============================================
# AWS CONFIGURATION
# ============================================
AWS_REGION=eu-west-1
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key

# ============================================
# LOGGING CONFIGURATION
# ============================================
LOG_FILE_PATH=./logs/app.log
LOG_FILE_MAX_SIZE=10m
LOG_FILE_MAX_FILES=10

# ============================================
# SECURITY CONFIGURATION
# ============================================
ENCRYPTION_KEY=your-encryption-key-32-chars
BCRYPT_ROUNDS=10
SESSION_TIMEOUT=3600000

# ============================================
# FEATURES FLAGS
# ============================================
ENABLE_SWAGGER_DOCS=true
ENABLE_METRICS=true
ENABLE_PROFILING=false
ENABLE_DEBUG_MODE=false

# ============================================
# PERFORMANCE CONFIGURATION
# ============================================
QUERY_CACHE_TTL=300000
SLOW_QUERY_THRESHOLD=1000
MAX_POOL_SIZE=20

# ============================================
# MONITORING & ALERTS
# ============================================
SENTRY_DSN=
ALERT_EMAIL_RECIPIENTS=admin@example.com
CRITICAL_ALERT_WEBHOOK=

# ============================================
# KUBERNETES CONFIGURATION
# ============================================
KUBERNETES_NAMESPACE=default
KUBERNETES_SERVICE_ACCOUNT=default

# ============================================
# DEVELOPMENT CONFIGURATION
# ============================================
# Only set these in development!
DEBUG=fleet:*
MOCK_GEOTAB=false
MOCK_IDEM=false
SEED_DATABASE_ON_STARTUP=false
