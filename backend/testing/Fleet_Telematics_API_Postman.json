              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"customerId\": \"demo-customer\",\n  \"firstName\": \"John\",\n  \"lastName\": \"Smith\",\n  \"email\": \"john.smith@example.com\",\n  \"phone\": \"+1234567890\",\n  \"licenseNumber\": \"DL123456\",\n  \"licenseExpiry\": \"2026-12-31\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/drivers",
              "host": ["{{baseUrl}}"],
              "path": ["drivers"]
            }
          }
        }
      ]
    },
    {
      "name": "Trailers",
      "item": [
        {
          "name": "Get All Trailers",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/trailers?customerId=demo-customer",
              "host": ["{{baseUrl}}"],
              "path": ["trailers"],
              "query": [
                {
                  "key": "customerId",
                  "value": "demo-customer"
                }
              ]
            }
          }
        },
        {
          "name": "Create Trailer",
          "request": {
            "method": "POST",
            "header": [
              {
