      ]
    },
    {
      "name": "Health",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/health",
              "host": ["{{baseUrl}}"],
              "path": ["health"]
            }
          }
        },
        {
          "name": "Health Detailed",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/health/detailed",
              "host": ["{{baseUrl}}"],
              "path": ["health", "detailed"]
            }
          }
        },
        {
          "name": "Health Metrics",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/health/metrics",
              "host": ["{{baseUrl}}"],
              "path": ["health", "metrics"]
            }
          }
        },
        {
          "name": "Health Ready",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/health/ready",
