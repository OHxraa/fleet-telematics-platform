              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"customerId\": \"demo-customer\",\n  \"name\": \"Refrigerated Trailer 001\",\n  \"licensePlate\": \"TRAILER001\",\n  \"trailerType\": \"refrigerated\",\n  \"hasRefrigeration\": true\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/trailers",
